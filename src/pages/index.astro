---
import BaseLayout from "../layouts/BaseLayout.astro";
import Hero from "../components/Hero.astro";
import BiographyChapter from "../components/BiographyChapter.astro";
import Timeline from "../components/Timeline.astro";
import GalleryGrid from "../components/GalleryGrid.astro";
import ScrollStopSection from "../components/ScrollStopSection.astro";
import { biographyChapters } from "../data/biography";
---

<BaseLayout>
  <Hero />

  <section class="introduction" id="introduction" aria-labelledby="intro-title">
    <div class="shell intro-grid" data-reveal>
      <p class="eyebrow">The purpose of this archive</p>
      <div>
        <h2 id="intro-title">A life remembered with care.</h2>
        <p class="lead">This website is being prepared to preserve the life, story, and legacy of Kurt Lettow Bildhaer through verified family knowledge and historical documentation.</p>
        <p class="placeholder-copy">Placeholder introduction. Replace this text with a reviewed account of the project’s purpose, its contributors, and the standards used to verify biographical material.</p>
      </div>
    </div>
  </section>

  <ScrollStopSection
    image="/images/archive-documents-placeholder.webp"
    alt="Fictional archival documents used as a visual placeholder"
    quote="A story worth preserving."
    label="The work of memory"
  />

  <section class="story-section" id="story" aria-labelledby="story-title">
    <div class="shell">
      <div class="section-heading story-heading" data-reveal>
        <p class="eyebrow">Six chapters</p>
        <h2 id="story-title">The biography</h2>
        <p>A chapter structure ready to hold verified dates, places, family histories, and personal memories.</p>
      </div>
      <div class="chapters">
        {biographyChapters.map((chapter, index) => <BiographyChapter chapter={chapter} index={index} />)}
      </div>
    </div>
  </section>

  <Timeline />

  <ScrollStopSection
    image="/images/family-archive-placeholder.webp"
    alt="Fictional family archive used as a visual placeholder"
    quote="Memory becomes legacy when it is preserved."
    label="Across generations"
    align="right"
  />

  <GalleryGrid />

  <section class="legacy-section" id="legacy" aria-labelledby="legacy-title">
    <div class="shell legacy-inner" data-reveal>
      <p class="eyebrow light">What remains</p>
      <h2 id="legacy-title">His story continues through family, memory, and the preservation of a life that deserves to be remembered.</h2>
      <p>This statement is proposed placeholder copy. It should be reviewed and approved by the family before publication.</p>
      <span class="legacy-mark" aria-hidden="true">KLB</span>
    </div>
  </section>

  <section class="references-section" id="references" aria-labelledby="references-title">
    <div class="shell references-grid" data-reveal>
      <div>
        <p class="eyebrow">Notes & provenance</p>
        <h2 id="references-title">References</h2>
      </div>
      <div class="reference-list">
        <p><span>01</span> Family interviews and contributions — contributors and dates to be added.</p>
        <p><span>02</span> Archival documents — repository, collection, and reference numbers pending.</p>
        <p><span>03</span> Published historical sources — full citations pending verification.</p>
        <p><span>04</span> Photographs and letters — ownership and usage permissions to be documented.</p>
        <a class="text-link" href="/references">View reference notes <span aria-hidden="true">→</span></a>
      </div>
    </div>
  </section>

  <section class="closing-section" aria-labelledby="closing-title">
    <div class="shell closing-inner" data-reveal>
      <p class="eyebrow">An open invitation</p>
      <h2 id="closing-title">Preserving the life and legacy of Kurt Lettow Bildhaer.</h2>
      <p>If you hold a photograph, document, memory, or correction that can strengthen this record, the archive is ready to listen.</p>
      <a class="button" href="mailto:family@example.com?subject=Kurt%20Lettow%20Bildhaer%20Biography">Share Information / Contact</a>
    </div>
  </section>
</BaseLayout>
