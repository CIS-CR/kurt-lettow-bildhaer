---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Das Buch | Kurt Lettow" description="Publikation und Beiträge zum Lebenswerk des Bildhauers Kurt Lettow.">
  <section class="internal-hero">
    <div class="shell" data-reveal><p class="eyebrow">Publikation</p><h1>Das Buch</h1><p>Kurt Lettow, Bildhauer, 1908-1992. Über die Grenzen Bremens hinaus.</p></div>
  </section>
  <section class="reference-page">
    <div class="shell reference-page-grid">
      <article data-reveal><span>01</span><h2>Umfang</h2><p>240 Seiten, mehr als 400 farbige Abbildungen, Hardcover.</p></article>
      <article data-reveal><span>02</span><h2>Werk</h2><p>Das Buch zeigt das christliche wie weltliche Werk Lettows, das im gesamten norddeutschen Raum zu finden ist.</p></article>
      <article data-reveal><span>03</span><h2>Beiträge</h2><p>Mit Beiträgen von Dr. Frank Laukötter, Dr. Arie Hartog, Prof. Dr. Georg Skalecki, Pastor Kunze, Rebekka Schwiddessen und weiteren Fachleuten.</p></article>
      <article data-reveal><span>04</span><h2>Dokumentation</h2><p>Die Publikation macht ein Werk sichtbar, dessen Umfang, Vielfalt und Präsenz weit über Bremen hinausreichen.</p></article>
    </div>
  </section>
</BaseLayout>
