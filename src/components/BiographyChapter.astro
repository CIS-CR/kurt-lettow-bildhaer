---
import type { BiographyChapter as Chapter } from "../data/biography";

interface Props { chapter: Chapter; index: number; }
const { chapter, index } = Astro.props;
const reverse = index % 2 === 1;
---

<article class:list={["biography__chapter", "reveal-on-scroll", { "biography__chapter--reverse": reverse }]} data-reveal>
  <div class="biography__content">
    <div class="biography__meta">
      <span class="biography__chapter-number" aria-hidden="true">{chapter.number}</span>
      <span class="biography__chapter-label">{chapter.label}</span>
    </div>
    <h3>{chapter.title}</h3>
    <p class="chapter-period">{chapter.period}</p>
    <div class="biography__chapter-text">
      {chapter.paragraphs.map((paragraph) => <p>{paragraph}</p>)}
    </div>
  </div>
  {chapter.image && (
    <figure
      class:list={["biography__media", { "biography__media--custom-ratio": chapter.imageRatio }]}
      style={chapter.imageRatio ? `--biography-image-ratio:${chapter.imageRatio}` : undefined}
    >
      <img
        class="biography__image"
        src={chapter.image}
        alt={chapter.imageAlt}
        loading="lazy"
        width={chapter.imageWidth || 1000}
        height={chapter.imageHeight || 1400}
        style={`object-position:${chapter.imagePosition || "center"}`}
      />
    </figure>
  )}
</article>
