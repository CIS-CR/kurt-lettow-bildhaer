---
import type { BiographyChapter as Chapter } from "../data/biography";

interface Props { chapter: Chapter; index: number; }
const { chapter, index } = Astro.props;
const reverse = index % 2 === 1;
---

<article class:list={["chapter", { reverse, "chapter-with-image": chapter.image }]} data-reveal>
  <div class="chapter-index" aria-hidden="true">{chapter.number}</div>
  <div class="chapter-copy biography__text reveal-on-scroll">
    <p class="eyebrow">Kapitel {chapter.number}</p>
    <h3>{chapter.title}</h3>
    <p class="chapter-period">{chapter.period}</p>
    <p>{chapter.summary}</p>
  </div>
  {chapter.image && (
    <figure class="chapter-media biography__media reveal-on-scroll">
      <img src={chapter.image} alt={chapter.imageAlt} loading="lazy" />
      <figcaption>Bildmaterial wird durch verifizierte Aufnahmen ersetzt</figcaption>
    </figure>
  )}
</article>
