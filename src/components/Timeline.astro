---
import { timelineEvents } from "../data/timeline";
---

<section class="timeline-section section-dark scroll-scene" id="timeline" aria-labelledby="timeline-title" data-scroll-scene="timeline">
  <div class="shell timeline-layout">
    <div class="section-heading sticky-heading" data-reveal>
      <p class="eyebrow light">Zeitleiste</p>
      <h2 id="timeline-title">Stationen eines Lebens und Werkes.</h2>
      <p>Eine verdichtete Chronologie von Ausbildung, Werk, Neubeginn und Wiederentdeckung.</p>
      <a class="text-link light-link" href="/timeline">Zeitleiste öffnen <span aria-hidden="true">→</span></a>
    </div>
    <ol class="timeline-list">
      {timelineEvents.map((event, index) => (
        <li class="timeline-item" data-reveal style={`--delay: ${index * 60}ms`}>
          <time>{event.year}</time>
          <div>
            <h3>{event.title}</h3>
            <p>{event.description}</p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
