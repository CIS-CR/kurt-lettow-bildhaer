---
import { homeTimelineEvents, type TimelineEvent } from "../data/timeline";

interface Props {
  events?: TimelineEvent[];
  intro?: string;
  variant?: "home" | "full";
}

const {
  events = homeTimelineEvents,
  intro = "Eine verdichtete Chronologie von Ausbildung, Werk, Neubeginn und Wiederentdeckung.",
  variant = "home",
} = Astro.props;
const full = variant === "full";
---

<section class:list={["timeline-section", "section-dark", "scroll-scene", { "timeline-section--full": full }]} id="timeline" aria-labelledby="timeline-title" data-scroll-scene="timeline">
  <div class="shell timeline-layout">
    <div class="section-heading sticky-heading" data-reveal>
      <p class="eyebrow light">Zeitleiste</p>
      <h2 id="timeline-title">Stationen eines Lebens und Werkes.</h2>
      <p>{intro}</p>
    </div>
    <ol class="timeline-list">
      {events.map((event, index) => (
        <li class:list={["timeline-item", { "timeline-item--with-media": full && event.image }]} data-reveal style={`--delay: ${index * 60}ms`}>
          <time>{event.year}</time>
          <div>
            <h3>{event.title}</h3>
            <p>{event.description}</p>
          </div>
          {full && event.image && (
            <figure class="timeline-media">
              <img src={event.image} alt={event.imageAlt || ""} loading="lazy" style={`object-position:${event.imagePosition || "center"}`} />
            </figure>
          )}
        </li>
      ))}
    </ol>
  </div>
</section>
