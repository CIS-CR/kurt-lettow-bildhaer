---
import { galleryItems } from "../data/gallery";
---

<section class="archive-section scroll-scene" id="archive" aria-labelledby="archive-title" data-scroll-scene="archive">
  <div class="shell">
    <div class="section-heading archive-heading" data-reveal>
      <div>
        <p class="eyebrow">Werk und Archiv</p>
        <h2 id="archive-title">Ein Werk in vielen Materialien.</h2>
      </div>
      <p>Lettows Arbeiten umfassen christliche und weltliche Werke, Reliefs, Plastiken, Portale und Wandgestaltungen. Sie zeigen ein feines Spiel von Licht und Schatten, eine reduzierte Formensprache und eine stille Kraft, die Raum für Betrachtung und Interpretation lässt.</p>
    </div>
    <div class="archive-grid">
      {galleryItems.map((item, index) => (
        <article class:list={["archive-item", { featured: index === 0 || index === 3 }]} data-reveal>
          <figure>
            <img src={item.image} alt={item.alt} loading="lazy" style={`object-position:${item.position || "center"}`} />
            <span>{String(index + 1).padStart(2, "0")}</span>
          </figure>
          <div class="archive-meta">
            <p>{item.category} · {item.date}</p>
            <h3>{item.title}</h3>
            <p>{item.description}</p>
          </div>
        </article>
      ))}
    </div>
    <a class="button button-outline" href="/archive">Archiv öffnen</a>
  </div>
</section>
